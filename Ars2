		BorderSizePixel = 0,
	}, row)
	addCorner(box, 3)
	addStroke(box, Color3.fromRGB(60, 60, 60))

	local fill = mk("Frame", {
		Size = UDim2.new(1, 0, 1, 0),
		BackgroundColor3 = GREEN,
		BackgroundTransparency = state and 0 or 1,
		BorderSizePixel = 0,
	}, box)
	addCorner(fill, 3)

	mk("TextLabel", {
