	local color = default or Color3.fromRGB(255, 255, 255)
	local h, s, v = Color3.toHSV(color)

	local row = mk("Frame", {
		Size = UDim2.new(1, 0, 0, 28),
		BackgroundColor3 = SUBPANEL,
		BorderSizePixel = 0,
	}, parent)
	addCorner(row, 4)
	addStroke(row, OUTLINE)

	mk("TextLabel", {
		Size = UDim2.new(0.6, 0, 1, 0),
		Position = UDim2.new(0, 8, 0, 0),
		Text = labelText,
		TextColor3 = TEXT,
		Font = Enum.Font.Gotham,
		TextSize = 12,
		BackgroundTransparency = 1,
		TextXAlignment = Enum.TextXAlignment.Left,
	}, row)

	local swatch = mk("TextButton", {
		Size = UDim2.new(0, 50, 0, 16),
		Position = UDim2.new(1, -60, 0.5, -8),
		BackgroundColor3 = color,
		BorderSizePixel = 0,
		Text = "",
	}, row)
	addCorner(swatch, 3)
	addStroke(swatch, OUTLINE)

	local pickerOpen = false
	local pickerFrame

	swatch.MouseButton1Click:Connect(function()
		closeActiveDropdown()
		pickerOpen = not pickerOpen

		if pickerOpen then
			pickerFrame = mk("Frame", {
				Size = UDim2.new(0, 180, 0, 160),
				Position = UDim2.new(0, 0, 0, 30),
				BackgroundColor3 = Color3.fromRGB(14, 14, 14),
				BorderSizePixel = 0,
				ZIndex = 200,
			}, row)
			addCorner(pickerFrame, 5)
			addStroke(pickerFrame, OUTLINE)
			addPadding(pickerFrame, 8, 8, 8, 8)

			local function makeHSVSlider(sliderParent, lbl, minV, maxV, defV, sliderCallback)
				local sRow = mk("Frame", {
					Size = UDim2.new(1, 0, 0, 32),
					BackgroundTransparency = 1,
					ZIndex = 201,
				}, sliderParent)
				mk("TextLabel", {
					Size = UDim2.new(0, 14, 0, 14),
					Position = UDim2.new(0, 0, 0, 0),
					Text = lbl,
					TextColor3 = TEXTDIM,
					Font = Enum.Font.GothamBold,
					TextSize = 9,
					BackgroundTransparency = 1,
					ZIndex = 201,
				}, sRow)

				local slTrack = mk("Frame", {
					Size = UDim2.new(1, 0, 0, 6),
					Position = UDim2.new(0, 0, 0, 16),
					BackgroundColor3 = Color3.fromRGB(35, 35, 35),
					BorderSizePixel = 0,
					ZIndex = 201,
				}, sRow)
				addCorner(slTrack, 3)

				local a0 = (defV - minV) / (maxV - minV)
				local slFill = mk("Frame", {
					Size = UDim2.new(a0, 0, 1, 0),
					BackgroundColor3 = GREEN,
					BorderSizePixel = 0,
					ZIndex = 202,
				}, slTrack)
				addCorner(slFill, 3)

				local slKnob = mk("Frame", {
					Size = UDim2.new(0, 10, 0, 10),
					Position = UDim2.new(a0, -5, 0.5, -5),
					BackgroundColor3 = Color3.fromRGB(230, 230, 230),
					BorderSizePixel = 0,
					ZIndex = 203,
				}, slTrack)
				addCorner(slKnob, 10)

				local sl2 = false
				slTrack.InputBegan:Connect(function(inp)
					if inp.UserInputType == Enum.UserInputType.MouseButton1 then sl2 = true end
				end)
				UIS.InputEnded:Connect(function(inp)
					if inp.UserInputType == Enum.UserInputType.MouseButton1 then sl2 = false end
				end)
				UIS.InputChanged:Connect(function(inp)
					if sl2 and inp.UserInputType == Enum.UserInputType.MouseMovement then
						local aa = math.clamp((inp.Position.X - slTrack.AbsolutePosition.X) / slTrack.AbsoluteSize.X, 0, 1)
						local newVal = minV + (maxV - minV) * aa
						slFill.Size = UDim2.new(aa, 0, 1, 0)
						slKnob.Position = UDim2.new(aa, -5, 0.5, -5)
						sliderCallback(newVal)
					end
				end)

				return sRow
			end

			mk("UIListLayout", { Padding = UDim.new(0, 6), SortOrder = Enum.SortOrder.LayoutOrder }, pickerFrame)

			makeHSVSlider(pickerFrame, "H", 0, 1, h, function(val2)
				h = val2; color = Color3.fromHSV(h, s, v)
				swatch.BackgroundColor3 = color; if callback then callback(color) end
			end)
			makeHSVSlider(pickerFrame, "S", 0, 1, s, function(val2)
				s = val2; color = Color3.fromHSV(h, s, v)
				swatch.BackgroundColor3 = color; if callback then callback(color) end
			end)
			makeHSVSlider(pickerFrame, "V", 0, 1, v, function(val2)
				v = val2; color = Color3.fromHSV(h, s, v)
				swatch.BackgroundColor3 = color; if callback then callback(color) end
			end)

			activeDropdown = function()
				pickerOpen = false
				if pickerFrame then pickerFrame:Destroy(); pickerFrame = nil end
			end
		else
			if pickerFrame then pickerFrame:Destroy(); pickerFrame = nil end
		end
	end)

	return row
end

