		BackgroundTransparency = 1,
		TextXAlignment = Enum.TextXAlignment.Left,
	}, row)

	local btn = mk("TextButton", {
		Size = UDim2.new(1, 0, 1, 0),
		BackgroundTransparency = 1,
		Text = "",
	}, row)

	btn.MouseEnter:Connect(function() tw(row, { BackgroundColor3 = Color3.fromRGB(22, 22, 22) }):Play() end)
	btn.MouseLeave:Connect(function() tw(row, { BackgroundColor3 = SUBPANEL }):Play() end)

	local function setState(val)
		state = val
		tw(fill, { BackgroundTransparency = state and 0 or 1 }, 0.1):Play()
		if callback then callback(state) end
	end

	btn.MouseButton1Click:Connect(function() setState(not state) end)

	return row, setState
end

local function mkSlider(parent, labelText, minV, maxV, default, callback)
	local val = default or minV

	local row = mk("Frame", {
		Size = UDim2.new(1, 0, 0, 40),
		BackgroundColor3 = SUBPANEL,
		BorderSizePixel = 0,
	}, parent)
	addCorner(row, 4)
	addStroke(row, OUTLINE)

	mk("TextLabel", {
		Size = UDim2.new(1, -60, 0, 18),
		Position = UDim2.new(0, 8, 0, 2),
		Text = labelText,
		TextColor3 = TEXT,
		Font = Enum.Font.Gotham,
		TextSize = 12,
		BackgroundTransparency = 1,
		TextXAlignment = Enum.TextXAlignment.Left,
	}, row)

	local valLbl = mk("TextLabel", {
		Size = UDim2.new(0, 50, 0, 18),
		Position = UDim2.new(1, -56, 0, 2),
		Text = tostring(val),
		TextColor3 = GREEN,
		Font = Enum.Font.GothamBold,
		TextSize = 12,
		BackgroundTransparency = 1,
		TextXAlignment = Enum.TextXAlignment.Right,
	}, row)

	local track = mk("Frame", {
		Size = UDim2.new(1, -16, 0, 4),
		Position = UDim2.new(0, 8, 0, 26),
		BackgroundColor3 = Color3.fromRGB(30, 30, 30),
		BorderSizePixel = 0,
	}, row)
	addCorner(track, 2)

	local alpha0 = (val - minV) / (maxV - minV)
	local filled = mk("Frame", {
		Size = UDim2.new(alpha0, 0, 1, 0),
		BackgroundColor3 = GREEN,
		BorderSizePixel = 0,
	}, track)
	addCorner(filled, 2)

	local knob = mk("Frame", {
		Size = UDim2.new(0, 10, 0, 10),
		Position = UDim2.new(alpha0, -5, 0.5, -5),
		BackgroundColor3 = Color3.fromRGB(240, 240, 240),
		BorderSizePixel = 0,
	}, track)
	addCorner(knob, 10)
	addStroke(knob, GREEN, 1)

	local sliding = false
	track.InputBegan:Connect(function(input)
		if input.UserInputType == Enum.UserInputType.MouseButton1 then sliding = true end
	end)
	UIS.InputEnded:Connect(function(input)
		if input.UserInputType == Enum.UserInputType.MouseButton1 then sliding = false end
	end)
	UIS.InputChanged:Connect(function(input)
		if sliding and input.UserInputType == Enum.UserInputType.MouseMovement then
			local a = math.clamp((input.Position.X - track.AbsolutePosition.X) / track.AbsoluteSize.X, 0, 1)
			val = math.floor(minV + (maxV - minV) * a)
			valLbl.Text = tostring(val)
			tw(filled, { Size = UDim2.new(a, 0, 1, 0) }, 0.04):Play()
			tw(knob, { Position = UDim2.new(a, -5, 0.5, -5) }, 0.04):Play()
			if callback then callback(val) end
		end
	end)

	return row
end

local function mkDropdown(parent, labelText, options, default, callback)
	local selected = default or options[1]

	local wrap = mk("Frame", {
		Size = UDim2.new(1, 0, 0, 28),
		BackgroundTransparency = 1,
		ClipsDescendants = false,
		ZIndex = 10,
	}, parent)

	local row = mk("Frame", {
		Size = UDim2.new(1, 0, 0, 28),
		BackgroundColor3 = SUBPANEL,
		BorderSizePixel = 0,
		ZIndex = 10,
	}, wrap)
	addCorner(row, 4)
	addStroke(row, OUTLINE)

	mk("TextLabel", {
		Size = UDim2.new(0.5, 0, 1, 0),
		Position = UDim2.new(0, 8, 0, 0),
		Text = labelText,
		TextColor3 = TEXT,
		Font = Enum.Font.Gotham,
		TextSize = 12,
		BackgroundTransparency = 1,
		TextXAlignment = Enum.TextXAlignment.Left,
		ZIndex = 10,
	}, row)

	local selLbl = mk("TextLabel", {
		Size = UDim2.new(0.5, -30, 1, 0),
		Position = UDim2.new(0.5, 0, 0, 0),
		Text = selected,
		TextColor3 = GREEN,
		Font = Enum.Font.GothamBold,
		TextSize = 12,
		BackgroundTransparency = 1,
		TextXAlignment = Enum.TextXAlignment.Right,
		ZIndex = 10,
	}, row)

	local arrow = mk("TextLabel", {
		Size = UDim2.new(0, 20, 1, 0),
		Position = UDim2.new(1, -22, 0, 0),
		Text = "v",
		TextColor3 = TEXTDIM,
		Font = Enum.Font.Gotham,
		TextSize = 10,
		BackgroundTransparency = 1,
		ZIndex = 10,
	}, row)

	local ddMenu = mk("Frame", {
		Size = UDim2.new(1, 0, 0, #options * 26 + 6),
		Position = UDim2.new(0, 0, 0, 30),
		BackgroundColor3 = Color3.fromRGB(16, 16, 16),
		BorderSizePixel = 0,
		ZIndex = 200,
		Visible = false,
	}, wrap)
	addCorner(ddMenu, 4)
	addStroke(ddMenu, OUTLINE)

	mk("UIListLayout", {
		Padding = UDim.new(0, 2),
		FillDirection = Enum.FillDirection.Vertical,
		HorizontalAlignment = Enum.HorizontalAlignment.Center,
		SortOrder = Enum.SortOrder.LayoutOrder,
	}, ddMenu)
	addPadding(ddMenu, 3, 3, 3, 3)

	local isOpen = false

	local function close()
		isOpen = false
		ddMenu.Visible = false
		tw(arrow, { TextColor3 = TEXTDIM }):Play()
		if activeDropdown == close then activeDropdown = nil end
	end

	for _, opt in ipairs(options) do
		local optBtn = mk("TextButton", {
			Size = UDim2.new(1, 0, 0, 22),
			BackgroundColor3 = opt == selected and Color3.fromRGB(0, 60, 30) or Color3.fromRGB(20, 20, 20),
			BorderSizePixel = 0,
			Text = opt,
			TextColor3 = opt == selected and GREEN or TEXT,
			Font = Enum.Font.Gotham,
			TextSize = 12,
			ZIndex = 201,
		}, ddMenu)
		addCorner(optBtn, 3)

		optBtn.MouseEnter:Connect(function()
			if opt ~= selected then tw(optBtn, { BackgroundColor3 = Color3.fromRGB(28, 28, 28) }):Play() end
		end)
		optBtn.MouseLeave:Connect(function()
			if opt ~= selected then tw(optBtn, { BackgroundColor3 = Color3.fromRGB(20, 20, 20) }):Play() end
		end)
		optBtn.MouseButton1Click:Connect(function()
			selected = opt
			selLbl.Text = opt
			if callback then callback(opt) end
			for _, c in ipairs(ddMenu:GetChildren()) do
				if c:IsA("TextButton") then
					local isSel = c.Text == selected
					tw(c, {
						BackgroundColor3 = isSel and Color3.fromRGB(0, 60, 30) or Color3.fromRGB(20, 20, 20),
						TextColor3 = isSel and GREEN or TEXT,
					}):Play()
				end
			end
			close()
		end)
	end

	local btn = mk("TextButton", {
		Size = UDim2.new(1, 0, 0, 28),
		BackgroundTransparency = 1,
		Text = "",
		ZIndex = 11,
	}, row)

	btn.MouseEnter:Connect(function() tw(row, { BackgroundColor3 = Color3.fromRGB(22, 22, 22) }):Play() end)
	btn.MouseLeave:Connect(function() tw(row, { BackgroundColor3 = SUBPANEL }):Play() end)
	btn.MouseButton1Click:Connect(function()
		if isOpen then
			close()
		else
			closeActiveDropdown()
			isOpen = true
			ddMenu.Visible = true
			tw(arrow, { TextColor3 = GREEN }):Play()
			activeDropdown = close
		end
	end)

	return wrap, function(v) selected = v; selLbl.Text = v end
end

local function mkHotkeyBox(parent, labelText, default, onBind)
	local currentKey = default

	local row = mk("Frame", {
		Size = UDim2.new(1, 0, 0, 28),
		BackgroundColor3 = SUBPANEL,
		BorderSizePixel = 0,
	}, parent)
	addCorner(row, 4)
	addStroke(row, OUTLINE)

	mk("TextLabel", {
		Size = UDim2.new(0.55, 0, 1, 0),
		Position = UDim2.new(0, 8, 0, 0),
		Text = labelText,
		TextColor3 = TEXT,
		Font = Enum.Font.Gotham,
		TextSize = 12,
		BackgroundTransparency = 1,
		TextXAlignment = Enum.TextXAlignment.Left,
	}, row)

	local keyBox = mk("TextButton", {
		Size = UDim2.new(0, 70, 0, 18),
		Position = UDim2.new(1, -78, 0.5, -9),
		BackgroundColor3 = Color3.fromRGB(20, 20, 20),
		BorderSizePixel = 0,
		Text = currentKey or "None",
		TextColor3 = currentKey and GREEN or TEXTDIM,
		Font = Enum.Font.GothamBold,
		TextSize = 11,
	}, row)
	addCorner(keyBox, 3)
	addStroke(keyBox, Color3.fromRGB(55, 55, 55))

	local listening = false

	keyBox.MouseButton1Click:Connect(function()
		if listening then return end
		listening = true
		keyBox.Text = "..."
		keyBox.TextColor3 = Color3.fromRGB(255, 220, 0)
		tw(keyBox, { BackgroundColor3 = Color3.fromRGB(30, 28, 10) }):Play()

		local conn
		conn = UIS.InputBegan:Connect(function(input, gpe)
			if not listening then return end
			listening = false

			local keyName
			if input.UserInputType == Enum.UserInputType.MouseButton1 then
				keyName = "LMB"
			elseif input.UserInputType == Enum.UserInputType.MouseButton2 then
				keyName = "RMB"
			elseif input.UserInputType == Enum.UserInputType.Keyboard then
				keyName = input.KeyCode.Name
			end

			currentKey = keyName
			keyBox.Text = keyName or "None"
			keyBox.TextColor3 = keyName and GREEN or TEXTDIM
			tw(keyBox, { BackgroundColor3 = Color3.fromRGB(20, 20, 20) }):Play()
			if onBind then onBind(currentKey) end
			conn:Disconnect()
		end)
	end)

	keyBox.MouseButton2Click:Connect(function()
		listening = false
		currentKey = nil
		keyBox.Text = "None"
		keyBox.TextColor3 = TEXTDIM
		tw(keyBox, { BackgroundColor3 = Color3.fromRGB(20, 20, 20) }):Play()
		if onBind then onBind(nil) end
	end)

	return row
end

