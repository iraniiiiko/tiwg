-- ============================================================
-- ALWAYS-ON ESP (Box + Health bar only, no settings)
-- ============================================================

local espDrawings = {}

local function clearESP(plr)
	if espDrawings[plr] then
		for _, d in pairs(espDrawings[plr]) do
			if d and d.Visible ~= nil then d.Visible = false end
		end
	end
end

local function removeESP(plr)
	if espDrawings[plr] then
		for _, d in pairs(espDrawings[plr]) do
			if d and d.Remove then d:Remove() end
		end
		espDrawings[plr] = nil
	end
end

local function setupESP(plr)
	if plr == player then return end
	removeESP(plr)

	local drawings = {}

	local boxOutline = Drawing.new("Square")
	boxOutline.Visible   = false
	boxOutline.Filled    = false
	boxOutline.Color     = settings.ESP.OutlineColor
	boxOutline.Thickness = settings.ESP.BoxThickness + 2
	drawings.boxOutline  = boxOutline

	local box = Drawing.new("Square")
	box.Visible   = false
	box.Filled    = false
	box.Color     = settings.ESP.BoxColor
	box.Thickness = settings.ESP.BoxThickness
	drawings.box  = box

	local healthBg = Drawing.new("Square")
	healthBg.Visible = false
	healthBg.Filled  = true
	healthBg.Color   = Color3.fromRGB(0, 0, 0)
	drawings.healthBg = healthBg

	local healthBar = Drawing.new("Square")
	healthBar.Visible = false
	healthBar.Filled  = true
	healthBar.Color   = Color3.fromRGB(0, 220, 80)
	drawings.healthBar = healthBar

	espDrawings[plr] = drawings
end

local function updateESPForPlayer(plr)
	local drawings = espDrawings[plr]
	if not drawings then return end

	local char = plr.Character
	if not char then clearESP(plr); return end

	local hrp  = char:FindFirstChild("HumanoidRootPart")
	local head = char:FindFirstChild("Head")
	local hum  = char:FindFirstChild("Humanoid")

	if not hrp or not head or not hum then clearESP(plr); return end
	if settings.ESP.TeamCheck and plr.Team == player.Team then clearESP(plr); return end

	local dist = (Camera.CFrame.Position - hrp.Position).Magnitude
	if dist > settings.ESP.MaxDistance then clearESP(plr); return end

	local topPos, topVis = Camera:WorldToViewportPoint(head.Position + Vector3.new(0, head.Size.Y / 2 + 0.1, 0))
	local botPos, _      = Camera:WorldToViewportPoint(hrp.Position  - Vector3.new(0, 3, 0))

	local show = topVis
	local boxH = math.abs(topPos.Y - botPos.Y)
	local boxW = boxH * 0.55
	local boxX = topPos.X - boxW / 2
	local boxY = topPos.Y

	if drawings.boxOutline then
		drawings.boxOutline.Visible = show and settings.ESP.OutlineEnabled
		if drawings.boxOutline.Visible then
			drawings.boxOutline.Position = Vector2.new(boxX - 1, boxY - 1)
			drawings.boxOutline.Size     = Vector2.new(boxW + 2, boxH + 2)
		end
	end

	if drawings.box then
		drawings.box.Visible   = show
		drawings.box.Color     = settings.ESP.BoxColor
		drawings.box.Thickness = settings.ESP.BoxThickness
		if drawings.box.Visible then
			drawings.box.Position = Vector2.new(boxX, boxY)
			drawings.box.Size     = Vector2.new(boxW, boxH)
		end
	end

	if drawings.healthBg and drawings.healthBar then
		local hpRatio = math.clamp(hum.Health / hum.MaxHealth, 0, 1)
		local barH    = boxH * hpRatio
		local bx      = boxX - 6
		local by      = boxY

		drawings.healthBg.Visible  = show
		drawings.healthBar.Visible = show

		if drawings.healthBg.Visible then
			drawings.healthBg.Position  = Vector2.new(bx, by)
			drawings.healthBg.Size      = Vector2.new(3, boxH)
			drawings.healthBar.Position = Vector2.new(bx, by + boxH - barH)
			drawings.healthBar.Size     = Vector2.new(3, barH)

			local r = 1 - hpRatio
			local g = hpRatio
			drawings.healthBar.Color = Color3.fromRGB(math.floor(r * 220), math.floor(g * 200), 50)
		end
	end
end

-- ============================================================
-- TARGET FINDING
-- Closest Part / Nearest Limb: smooth screen-dist weighted
-- blending across all parts, not a hard snap to one.
-- ============================================================

-- Smoothed aim position state
local smoothedAimPos = nil
local AIM_BLEND_SPEED = 12  -- higher = more responsive, lower = floatier

local function getPartWeight(part, screenCenter)
	-- Returns 1 / screenDist so closer-to-reticle parts score higher
	local sp, vis = Camera:WorldToViewportPoint(part.Position)
	if not vis then return nil, nil end
	local d = (Vector2.new(sp.X, sp.Y) - screenCenter).Magnitude
	return d, part.Position
end

local function getBestClosestPos(char, screenCenter)
	-- Weighted average of all visible parts, biased toward reticle-center
	local totalWeight = 0
	local weightedPos = Vector3.new(0, 0, 0)

	for _, part in ipairs(char:GetChildren()) do
		if part:IsA("BasePart") then
			local dist, pos = getPartWeight(part, screenCenter)
			if dist and dist < settings.AimAssist.FOV then
				-- Inverse-square weighting so nearest-to-reticle dominates gently
				local w = 1 / (dist^1.5 + 1)
				totalWeight = totalWeight + w
				weightedPos = weightedPos + pos * w
			end
		end
	end

	if totalWeight > 0 then
		return weightedPos / totalWeight
	end

	-- fallback: HRP
	local hrp = char:FindFirstChild("HumanoidRootPart")
	return hrp and hrp.Position or nil
end

local function getNearestTarget()
	local screenCenter = Vector2.new(Camera.ViewportSize.X / 2, Camera.ViewportSize.Y / 2)
	local closest     = nil
	local closestDist = math.huge

	for _, plr in ipairs(Players:GetPlayers()) do
		if plr == player then continue end
		if settings.AimAssist.TeamCheck and plr.Team == player.Team then continue end

		local char = plr.Character
		if not char then continue end

		local hum = char:FindFirstChildOfClass("Humanoid")
		if not hum or hum.Health <= 0 then continue end

		local partSetting = settings.AimAssist.Part
		local aimPos

		if partSetting == "Closest Part" or partSetting == "Nearest Limb" then
			aimPos = getBestClosestPos(char, screenCenter)
		elseif partSetting == "Torso" then
			local t = char:FindFirstChild("UpperTorso") or char:FindFirstChild("Torso")
			aimPos  = t and t.Position
		else
			local p = char:FindFirstChild(partSetting)
			aimPos  = p and p.Position
		end

		if not aimPos then
			local hrp = char:FindFirstChild("HumanoidRootPart")
			aimPos    = hrp and hrp.Position
		end
		if not aimPos then continue end

		local worldDist = (Camera.CFrame.Position - aimPos).Magnitude
		if worldDist > settings.AimAssist.MaxDistance then continue end

		-- Linear velocity prediction
		if settings.AimAssist.PredictMovement then
			local hrp = char:FindFirstChild("HumanoidRootPart")
			if hrp then aimPos = aimPos + hrp.AssemblyLinearVelocity * (1 / 60 * 2) end
		end

		-- Wall check
		if settings.AimAssist.WallCheck then
			local origin    = Camera.CFrame.Position
			local direction = aimPos - origin
			local rayParams = RaycastParams.new()
			rayParams.FilterDescendantsInstances = { player.Character }
			rayParams.FilterType = Enum.RaycastFilterType.Exclude
			local result = workspace:Raycast(origin, direction, rayParams)
			if result and result.Instance and not char:IsAncestorOf(result.Instance) then continue end
		end

		local sp, vis = Camera:WorldToViewportPoint(aimPos)
		if not vis then continue end

		local screenDist = (Vector2.new(sp.X, sp.Y) - screenCenter).Magnitude
		if screenDist > settings.AimAssist.FOV then continue end

		if screenDist < closestDist then
			closestDist = screenDist
			closest     = { predictedPos = aimPos }
		end
	end

	return closest
end

-- ============================================================
-- AIM ACTIVE STATE
-- ============================================================

local aimActive = false

UIS.InputBegan:Connect(function(input, gpe)
	if gpe then return end
	local bind = settings.AimAssist.HotKeyBind
	local triggered = false

	if bind == "RMB" and input.UserInputType == Enum.UserInputType.MouseButton2 then
		triggered = true
	elseif bind == "LMB" and input.UserInputType == Enum.UserInputType.MouseButton1 then
		triggered = true
	elseif bind and bind ~= "None" and input.UserInputType == Enum.UserInputType.Keyboard then
		if input.KeyCode.Name == bind then triggered = true end
	end

	if triggered then
		if settings.AimAssist.Mode == "Toggle" then
			aimActive = not aimActive
		else
			aimActive = true
		end
	end
end)

UIS.InputEnded:Connect(function(input)
	if settings.AimAssist.Mode ~= "Hold" then return end
	local bind = settings.AimAssist.HotKeyBind
	local released = false

	if bind == "RMB" and input.UserInputType == Enum.UserInputType.MouseButton2 then released = true
	elseif bind == "LMB" and input.UserInputType == Enum.UserInputType.MouseButton1 then released = true
	elseif bind and bind ~= "None" and input.UserInputType == Enum.UserInputType.Keyboard then
		if input.KeyCode.Name == bind then released = true end
	end

	if released then
		aimActive = false
		smoothedAimPos = nil -- reset smooth state on release so next lock-on starts fresh
	end
end)

-- ============================================================
-- RENDER LOOP
-- ============================================================

RunService.RenderStepped:Connect(function(dt)
	updateFOVCircle()

	for _, plr in ipairs(Players:GetPlayers()) do
		if plr ~= player then
			if not espDrawings[plr] then setupESP(plr) end
			updateESPForPlayer(plr)
		end
	end

	if not (settings.AimAssist.Enabled and aimActive) then
		smoothedAimPos = nil
		return
	end

	local result = getNearestTarget()
	if not result then
		smoothedAimPos = nil
		return
	end

	local rawAimPos = result.predictedPos

	-- Smoothly interpolate the world-space aim position
	-- This removes all snappiness regardless of which part mode is used
	if smoothedAimPos == nil then
		smoothedAimPos = rawAimPos
	else
		local blendSpeed = settings.AimAssist.Smoothness == 0
			and 1  -- instant when smoothness = 0
			or  AIM_BLEND_SPEED * (1 - settings.AimAssist.Smoothness / 110)

		local alpha = math.clamp(blendSpeed * dt, 0, 1)
		smoothedAimPos = smoothedAimPos:Lerp(rawAimPos, alpha)
	end

	local camPos   = Camera.CFrame.Position
	local direction = (smoothedAimPos - camPos).Unit
	local currentCF = Camera.CFrame
	local goalCF    = CFrame.lookAt(camPos, camPos + direction)

	-- Additional per-frame camera lerp on top of the world-pos lerp
	-- keeps the rotation itself silky even at high blend speeds
	local smooth = settings.AimAssist.Smoothness
	local alpha  = math.clamp(1 - (smooth / 105), 0.02, 1)
	Camera.CFrame = currentCF:Lerp(goalCF, alpha)
end)

