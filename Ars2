local guiOpen = false

local function setGuiOpen(open)
	guiOpen = open
	if open then
		main.Visible = true
		tw(main, { Size = UDim2.new(0, MAIN_W, 0, MAIN_H), BackgroundTransparency = 0 }, 0.25, Enum.EasingStyle.Back, Enum.EasingDirection.Out):Play()
		UIS.MouseIconEnabled = false
		cursorImg.Visible = true
	else
		tw(main, { BackgroundTransparency = 1 }, 0.15):Play()
		tw(main, { Size = UDim2.new(0, MAIN_W, 0, 0) }, 0.15):Play()
		task.delay(0.18, function() if not guiOpen then main.Visible = false end end)
		UIS.MouseIconEnabled = true
		cursorImg.Visible = false
	end
end

-- Move cursor image to follow mouse
RunService.RenderStepped:Connect(function()
	if guiOpen then
		local mp = UIS:GetMouseLocation()
		cursorImg.Position = UDim2.new(0, mp.X, 0, mp.Y)
	end
end)

UIS.InputBegan:Connect(function(input, gpe)
	if gpe then return end
	if input.KeyCode == Enum.KeyCode.P then
		setGuiOpen(not guiOpen)
	end
end)

